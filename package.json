{
  "name": "opsmind-ai",
  "version": "1.0.0",
  "description": "OpsMind AI - RAG System with React and Node.js",
  "main": "index.js",
  "scripts": {
    "start": "concurrently \"npm run backend\" \"npm run frontend\"",
    "backend": "npm start --prefix backend",
    "frontend": "npm start --prefix frontend",
    "install-all": "npm install && cd frontend && npm install && cd ../backend && npm install",
    "dev": "concurrently \"npm run backend:dev\" \"npm run frontend\"",
    "backend:dev": "cd backend && nodemon server.js"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "keywords": ["rag", "ai", "react", "node", "mongodb", "gemini"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.3"
  }
}
