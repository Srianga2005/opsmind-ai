# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/opmind-ai

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# Google AI (Gemini)
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# Groq API (Alternative to Gemini)
GROQ_API_KEY=your_groq_api_key_here

# Vector Database
VECTOR_DB_URI=your_mongodb_atlas_uri_here

# File Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760 # 10MB

# Redis (for BullMQ)
REDIS_URL=redis://localhost:6379
